{
  "manifest_version": 3,
  "name": "IP CIDR Calculator",
  "version": "0.1.0",
  "description": "Calculate IPv4 CIDR ranges, subnet masks, and related network information.",
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "IP CIDR Calculator",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  }
}
